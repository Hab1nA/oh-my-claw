{
  "name": "openclaw-minimal",
  "version": "0.1.0",
  "description": "A local-first AI Agent framework - Minimal implementation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node examples/simple-app.ts",
    "dev:src": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts --quiet",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "automation",
    "local-first"
